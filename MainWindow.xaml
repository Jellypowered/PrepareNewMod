<Window x:Class="PrepareNewMod.Source.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prepare New Mod — RimWorld Mod Template Generator"
        MinWidth="880" MinHeight="540"
        Width="1000" Height="660"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>

        <!-- TextBox style -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#D4D4D4"/>
            <Setter Property="SelectionBrush" Value="#264F78"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary button (Browse, Dry Run, Copy Log) -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#3A3D41"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#505355"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2D30"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary button (Copy & Apply) -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1177BB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0A4F80"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox style -->
        <Style x:Key="ModCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Field label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CDCFE"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== Config Panel ===== -->
        <Border Grid.Row="0" Background="#252526" CornerRadius="4" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Template root -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Template root:" Style="{StaticResource FieldLabel}" Margin="0,0,12,6"/>
                <TextBox x:Name="txtTemplateRoot" Grid.Row="0" Grid.Column="1" Style="{StaticResource InputStyle}" Margin="0,0,8,6"/>
                <Button Grid.Row="0" Grid.Column="2" Content="Browse" Style="{StaticResource SecondaryBtn}" Margin="0,0,0,6" Click="BrowseTemplateRoot_Click"/>

                <!-- Destination base -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Destination base:" Style="{StaticResource FieldLabel}" Margin="0,0,12,6"/>
                <TextBox x:Name="txtDestBase" Grid.Row="1" Grid.Column="1" Style="{StaticResource InputStyle}" Margin="0,0,8,6"/>
                <Button Grid.Row="1" Grid.Column="2" Content="Browse" Style="{StaticResource SecondaryBtn}" Margin="0,0,0,6" Click="BrowseDestBase_Click"/>

                <!-- Mod name -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="New mod name:" Style="{StaticResource FieldLabel}" Margin="0,0,12,6"/>
                <TextBox x:Name="txtModName" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Style="{StaticResource InputStyle}" Margin="0,0,0,6"/>

                <!-- Namespace override -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Namespace (optional):" Style="{StaticResource FieldLabel}" Margin="0,0,12,6"/>
                <TextBox x:Name="txtNamespace" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Style="{StaticResource InputStyle}" Margin="0,0,0,6"/>

                <!-- Package prefix -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Package ID prefix:" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtPkgPrefix" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Style="{StaticResource InputStyle}"/>

                <!-- Options -->
                <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal">
                    <CheckBox x:Name="chkIncludeGit" Content="Include .git (copy Git history)"
                              Style="{StaticResource ModCheck}" Margin="0,0,24,0"/>
                    <CheckBox x:Name="chkOpenWhenDone" Content="Open destination when done"
                              Style="{StaticResource ModCheck}" IsChecked="True"/>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3"
                            Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnDryRun" Content="Dry Run"
                            Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0" Click="BtnDryRun_Click"/>
                    <Button x:Name="btnRun" Content="Copy &amp; Apply"
                            Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0" Click="BtnRun_Click"/>
                    <Button x:Name="btnCopyLog" Content="Copy Log"
                            Style="{StaticResource SecondaryBtn}" Click="BtnCopyLog_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Log Area ===== -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="OUTPUT LOG"
                       Foreground="#505050" FontSize="10" FontWeight="Bold"
                       Margin="4,0,0,4"/>

            <TextBox x:Name="logBox" Grid.Row="1"
                     Background="#0D0D0D" Foreground="#4EC9B0"
                     FontFamily="Consolas" FontSize="11"
                     IsReadOnly="True"
                     BorderThickness="1" BorderBrush="#2D2D2D"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     Padding="8"
                     AcceptsReturn="True"/>
        </Grid>
    </Grid>
</Window>
